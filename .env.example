# Copy to .env and fill in values.
# The .env file is gitignored — never commit it.

# Local development only (ignored in production where Caddy takes port 80/443)
METABASE_PORT=3000

# Production: your domain name, e.g. bhl.example.com
DOMAIN=bhl.example.com

# Metabase public URL — used in shared links and embeds
# Locally this defaults to http://localhost:3000
MB_SITE_URL=https://bhl.example.com
